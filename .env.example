# ==============================================================================
# STOQUE FISCAL INTELLIGENCE (SFI) - ARQUIVO DE EXEMPLO DE CONFIGURAÇÃO (.env)
# Copie este arquivo para ".env" e substitua pelos valores reais do seu ambiente.
# ==============================================================================

# Google AI Studio (Necessário para a extração com Gemini)
GEMINI_API_KEY=sua_chave_do_gemini_aqui

# Integração com Microsoft Graph (Opcional - Monitoramento de E-mail)
TENANT_ID=seu_tenant_id_azure
CLIENT_ID=seu_client_id_azure
CLIENT_SECRET=seu_client_secret_azure
USER_EMAIL=email_monitorado@empresa.com.br

# Integração Zeev / Orquestra BPM (Consulta & Inicialização de Processos)
# URL base do portal Zeev (ex: https://corporativo.orquestrabpm.com.br)
ZEEV_API_URL=https://seu_endereco.do.zeev

# Token Bearer fornecido pelas configurações de Integração do Zeev
ZEEV_API_TOKEN=seu_token_api_zeev_aqui
